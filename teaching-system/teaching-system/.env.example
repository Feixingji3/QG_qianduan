# 教学管理系统 - 环境配置模板
# 复制此文件为 .env 并填写实际配置值

# ========================================
# JWT 密钥配置
# ========================================
# 用于签发和验证 JWT Token 的密钥
# 生产环境请使用复杂随机字符串，长度建议 32 位以上
JWT_SECRET=your_secret_key_here_change_in_production

# JWT 过期时间（单位：秒）
# 默认 24 小时 = 86400 秒
JWT_EXPIRES_IN=86400

# ========================================
# 数据库配置
# ========================================
# MySQL 数据库连接配置
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=teaching_mgmt
DB_PORT=3306

# 数据库连接池配置
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
